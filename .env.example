# ─── DATABASE ────────────────────────────────────────────────────────────────
# For VPS: file:./dev.db
# For Vercel/PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="file:./dev.db"

# ─── AUTHENTICATION ──────────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your_secure_auth_token_here"

# ─── GLOBAL SITE LOCK ────────────────────────────────────────────────────────
# Master password to access the site (pre-release mode)
SITE_PASSWORD="1234qwerty"

# ─── EXTERNAL SERVICES ───────────────────────────────────────────────────────
# SMS.ru API Key for OTP authentication
SMSRU_API_KEY="your_smsru_api_key_here"

# 2GIS API Key for address suggestions
DGIS_API_KEY="your_2gis_key_here"
NEXT_PUBLIC_2GIS_API_KEY="your_2gis_key_here"

# Yandex Maps API Key (Geocoder)
YANDEX_GEOCODER_KEY="your_yandex_key_here"
NEXT_PUBLIC_YANDEX_MAPS_API_KEY="your_yandex_key_here"

# ─── INFRASTRUCTURE ─────────────────────────────────────────────────────────
# The canonical URL of your deployed site
NEXT_PUBLIC_SITE_URL="https://smuslest.ru"
